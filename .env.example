# =============================================================================
# Cascade — environment variables
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# =============================================================================

# ---- MongoDB Atlas ---------------------------------------------------------
# From Atlas → Connect → Drivers. M0 free tier is fine.
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=cascade

# ---- Voyage AI (via Atlas Embedding & Reranking API) -----------------------
# 200M tokens free for new accounts. Voyage key is also bound inside Atlas
# at vector-index creation for Automated Embedding.
VOYAGE_API_KEY=pa-...
# voyage-3-large is paid-tier only for new accounts. Use voyage-4 instead
# (newest, also 1024-dim, free 200M tokens). Account-level cap is 3 RPM
# until a payment method is added at dashboard.voyageai.com/billing
# (no charge — adding a card just lifts the rate limit).
VOYAGE_TEXT_MODEL=voyage-4
VOYAGE_MULTIMODAL_MODEL=voyage-multimodal-3.5
VOYAGE_RERANK_MODEL=rerank-2.5

# ---- Google Cloud / Vertex AI ----------------------------------------------
GOOGLE_CLOUD_PROJECT=cascade-prod
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=./gcp-key.json
GEMINI_MODEL=gemini-2.5-pro
# Optional direct Gemini key (only if not using ADC):
GEMINI_API_KEY=

# ---- Data sources ----------------------------------------------------------
# SEC EDGAR REQUIRES a User-Agent header — requests without it are blocked.
SEC_USER_AGENT=Cascade research/your-email@example.com

FINNHUB_API_KEY=
MARKETAUX_API_KEY=
ALPHA_VANTAGE_API_KEY=

REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=cascade-research/0.1 by your-reddit-username

# ---- App config ------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8080
LOG_LEVEL=INFO

# HMAC secret for the on-camera /api/admin/replay-cascade endpoint (Phase 7).
REPLAY_HMAC_SECRET=change-me

# ---- Frontend (web/) -------------------------------------------------------
# Public — exposed to the browser. Point at the deployed Cloud Run URL.
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_SSE_URL=http://localhost:8080/stream
